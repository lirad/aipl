# ============================================
# AIPL — Environment Variables
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================

# ── Required ─────────────────────────────────
# Your Google Gemini API key (free tier available)
#
# How to get one:
#   1. Go to https://aistudio.google.com/apikey
#   2. Sign in with your Google account
#   3. Click "Create API Key"
#   4. Select any Google Cloud project (or create one)
#   5. Copy the key and paste it below
#
# The free tier includes 15 requests/minute — enough for learning.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional (Cloud Mode Only) ───────────────
# These are only needed if you deploy to Railway with analytics.
# For local development, you can ignore everything below.
#
# VITE_API_URL=https://your-app.up.railway.app
# REDIS_URL=redis://user:password@host:port
# ADMIN_KEY=your_secret_admin_key
# PORT=3001
